{
  "name": "node-trashkek",
  "version": "1.6.0",
  "engines": {
    "node": "17.x",
    "npm": "8.x"
  },
  "main": "index.js",
  "scripts": {
    "start": "node ./dist/index",
    "build": "tsc -p tsconfig.json",
    "ts-dev": "ts-node-dev -r dotenv/config ./src/index",
    "dev": "node -r dotenv/config ./dist/index",
    "devng": "WH_URL=$(curl http://127.0.0.1:4040/api/tunnels | jq -r .tunnels[0].public_url) && node -r dotenv/config index && WH_URL="
  },
  "dependencies": {
    "axios": "^0.24.0",
    "dotenv": "^10.0.0",
    "kektg": "github:meetmonday/kektg",
    "telegram-typings": "^5.0.0",
    "tiktok-scraper-without-watermark": "^1.1.3",
    "turndown": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^17.0.18",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.4",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.5.5"
  }
}
